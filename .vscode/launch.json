{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pnpm dev (Frontend)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/nextjs-fe",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Backend (C#)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/dotnet-be/auth-dotnet-api.csproj"
    }
  ],
  "compounds": [
    {
      "name": "Debug Fullstack (Both)",
      "configurations": ["pnpm dev (Frontend)", "Debug Backend (C#)"],
      "stopAll": true
    }
  ]
}